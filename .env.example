# Heroku Postgres Connection URL (Use local PostgreSQL configuration for development)
# Heroku automatically provides this in production, but you can set it here for local testing.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/resume_analyzer

# Embedding Model Configurations
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
DEFAULT_INCLUDE_EMBEDDING=true
TRANSFORMERS_CACHE=./models/cache
EMBEDDING_DEVICE=cpu
